# Copy to .env.local (gitignored) for local development.
# In production, set these values in your hosting provider's env settings.

# Supabase project for the online leaderboard.
# Find these in your Supabase project's "API" settings page.
# The anon key is designed to be used in browser clients; row-level security
# and table constraints (see supabase/schema.sql) keep it safe to expose.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Enable the Dev Mode challenge in a production-style build. Leave unset or
# set to "false" for public builds so the sandbox card is hidden.
# `npm run dev` always enables Dev Mode regardless of this flag.
VITE_ENABLE_DEV_CHALLENGE=false
